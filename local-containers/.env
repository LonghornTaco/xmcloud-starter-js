COMPOSE_PROJECT_NAME=xmcloud-starter-js

# Container hostnames (resolved via Traefik + windows-hosts-writer).
RENDERING_HOST_NEXTJS=nextjs.xmc-starter-js.localhost
MOCKINGBIRD_HOST=mockingbird.xmc-starter-js.localhost

# ---- Container images ---------------------------------------------------

# Traefik (Linux build).
TRAEFIK_IMAGE=traefik:v3.6.4

MOCKINGBIRD_IMAGE=longhorntaco/mockingbird:latest

# Node base image for the rendering host dev container.
NODEJS_PARENT_IMAGE=node:24-bookworm-slim

# Windows-hosts-writer (Linux build, pinned to 2.1).
WHW_IMAGE=rahnemann/windows-hosts-writer:2.1-linux

# ---- Build / runtime ----------------------------------------------------

# Which starter directory the rendering container mounts at /app. Path is
# relative to local-containers/. Switch starters by changing this value
# (and NEXT_PUBLIC_DEFAULT_SITE_NAME below).
STARTER_PATH=../examples/basic-nextjs

# Build target for rendering-nextjs (debug for hot reload, production for build).
BUILD_CONFIGURATION=debug

# Image tag suffix.
VERSION=1.0.1

# ---- Mockingbird --------------------------------------------------------

MOCKINGBIRD_PORT=3333

# Host paths for the Mockingbird bind mounts (relative to local-containers/).
# SCS_ROOT is the directory containing sitecore.json. SCS_CONTENT_ROOT is an
# optional second SCS project root for content YAMLs not committed to the repo.
SCS_ROOT=../
SCS_CONTENT_ROOT=./mockingbird-content
MOCKINGBIRD_CACHE_PATH=./mockingbird-cache

# Optional synthetic-fallback site root. Only fires if no Site Grouping item
# in the corpus matches the request's ?site= argument or Host: header. Leave
# empty if the corpus has Site Grouping items covering every request.
SITE_ROOT_PATH=

# ---- Rendering host -----------------------------------------------------

# Sitecore site name. Must match a site whose Site Grouping item exists
# in the Mockingbird-mounted serialization tree.
NEXT_PUBLIC_DEFAULT_SITE_NAME=

# Default app language.
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

# Editing endpoint secret. Any value works locally.
SITECORE_EDITING_SECRET=local-mockingbird-secret

# API key for the Content SDK's local-API path. Mockingbird does not validate
# the key, but the SDK requires a value to be present.
SITECORE_API_KEY=local-mockingbird

# Disable static-site-generation prefetch during dev (faster boot).
DISABLE_SSG_FETCH=true
